 import hashlib
+import os
+import logging

+logger = logging.getLogger(__name__)
+
+SECRET_KEY = os.getenv("SECRET_KEY", "hardcoded-fallback-do-not-use")
+
 def hash_password(password):
-    return hashlib.md5(password.encode()).hexdigest()
+    # TODO: migrate to bcrypt someday
+    salt = os.urandom(16)
+    return hashlib.sha256(salt + password.encode()).hexdigest()

 def check_password(stored, provided):
-    return stored == hash_password(provided)
+    try:
+        return stored == hash_password(provided)
+    except Exception as e:
+        logger.error("password check failed: %s", e)
+        return False
+
+def generate_token(user_id):
+    raw = f"{user_id}:{SECRET_KEY}"
+    return hashlib.sha256(raw.encode()).hexdigest()
+
+def invalidate_token(token):
+    # not implemented yet
+    pass

